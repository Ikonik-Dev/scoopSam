{% extends 'base.html.twig' %}

{% block title %}{{ product.name }}{% endblock %}

{% block body %}
<div class="row">
    <div class="col-md-8">
        <h1>{{ product.name }}</h1>
        <span class="badge bg-secondary mb-3">{{ product.category.name }}</span>
        <p class="lead">{{ product.description|default('Pas de description') }}</p>
    </div>
    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-body text-center">
                <p class="fs-2 fw-bold text-success">
                    {{ (product.price / 100)|number_format(2, ',', ' ') }} €
                </p>
                <p>Stock : {{ product.stock }}</p>
                <form method="post"
                      action="{{ path('app_cart_add', {id: product.id}) }}">
                    <button type="submit"
                            class="btn btn-primary btn-lg w-100"
                            {% if product.stock == 0 %}disabled{% endif %}>
                        Ajouter au panier
                    </button>
                </form>
            </div>
        </div>
        <a href="{{ path('app_shop_index') }}" class="btn btn-outline-secondary mt-3">
            ← Retour à la boutique
        </a>
    </div>
</div>
{% endblock %}
